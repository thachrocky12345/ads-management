# ── Anthropic ──────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Google Analytics 4 ────────────────────
# Service account JSON key file path
GA4_CREDENTIALS_PATH=./ga4_service_account.json
# Your GA4 Property ID (found in GA4 Admin > Property Settings)
GA4_PROPERTY_ID=properties/123456789

# ── HubSpot ───────────────────────────────
# Private App token (HubSpot > Settings > Integrations > Private Apps)
HUBSPOT_ACCESS_TOKEN=pat-na1-...

# ── Meta Pixel (for segment enrichment) ──
META_PIXEL_ID=1234567890
META_ACCESS_TOKEN=EAAxxxx...

# ── Pipeline settings ─────────────────────
ANALYSIS_LOOKBACK_DAYS=7
LOG_LEVEL=INFO
